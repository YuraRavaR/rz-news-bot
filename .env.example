# ─── Telegram ────────────────────────────────────────────────────────────────
# Отримати: @BotFather → /newbot
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ

# ID каналу (зі знаком мінус для публічних каналів)
# Отримати: додай @userinfobot в канал або скористайся /getUpdates
TELEGRAM_CHANNEL_ID=-1001234567890

# (Опційно) ID особистого чату або приватної групи для адмін-звітів після кожного рану
# Якщо не вказати — адмін-звіти надсилатимуться в основний канал
# Отримати: напиши /start боту, потім GET https://api.telegram.org/bot<TOKEN>/getUpdates
# TELEGRAM_ADMIN_CHAT_ID=123456789

# ─── Gemini AI ───────────────────────────────────────────────────────────────
# Отримати: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSy...

# ─── Turso (libsql) ──────────────────────────────────────────────────────────
# Отримати:
#   turso db create rz-flow
#   turso db show rz-flow --url   → TURSO_DATABASE_URL
#   turso db tokens create rz-flow → TURSO_AUTH_TOKEN
TURSO_DATABASE_URL=libsql://rz-flow-<username>.turso.io
TURSO_AUTH_TOKEN=eyJhbGciOiJF...

# ─── Staging (опційно, для `uv run rz-flow --staging`) ───────────────────────
# Окремий канал і ОКРЕМА Turso БД — інакше дедуплікація зламає продакшен.
#   turso db create rz-flow-staging
#   turso db show rz-flow-staging --url
#   turso db tokens create rz-flow-staging
# TELEGRAM_STAGING_CHANNEL_ID=-1009876543210
# TURSO_STAGING_DATABASE_URL=libsql://rz-flow-staging-<username>.turso.io
# TURSO_STAGING_AUTH_TOKEN=eyJhbGciOiJF...

# ─── App settings ────────────────────────────────────────────────────────────
# Мінімальний score (0–10) для публікації у канал
AI_MIN_SCORE=7

# Ім'я джерела для логів та алертів
APP_ENV=production
